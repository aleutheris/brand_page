{
  "name": "brand_page",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "22.x",
    "npm": "10.x"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "check": "astro check && tsc --noEmit",
    "lint": "eslint src eslint.config.mjs astro.config.mjs",
    "format": "prettier --write \"src/**/*\" \"*.{mjs,json}\" \".github/workflows/*.yml\"",
    "format:check": "prettier --check \"src/**/*\" \"*.{mjs,json}\" \".github/workflows/*.yml\""
  },
  "dependencies": {
    "astro": "5.0.0"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.4",
    "@eslint/js": "9.22.0",
    "@types/node": "22.13.10",
    "eslint": "9.22.0",
    "eslint-plugin-astro": "0.34.0",
    "globals": "15.15.0",
    "prettier": "3.5.3",
    "prettier-plugin-astro": "0.14.1",
    "typescript": "5.8.2",
    "typescript-eslint": "8.26.1"
  }
}
