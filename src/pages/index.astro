---
import BaseLayout from "../layouts/BaseLayout.astro";
import { withBase } from "../lib/withBase";

const base = import.meta.env.BASE_URL;
const projectsUrl = withBase(base, "projects/");

const heroSignals = [
  { symbol: "⚙", label: "Automation" },
  { symbol: "✦", label: "AI systems" },
  { symbol: "↗", label: "Operational clarity" },
];

const services = [
  {
    symbol: "⚙",
    title: "Workflow Automation",
    text: "Replace manual repetitive tasks with automations that save time, reduce errors, and free your team to focus on higher-value work.",
  },
  {
    symbol: "✦",
    title: "AI-Enabled Operations",
    text: "Use AI where it genuinely helps, whether that means speeding up routine tasks, making information easier to work with, or supporting better day-to-day decisions.",
  },
  {
    symbol: "◫",
    title: "Custom Software Solutions",
    text: "Design and build focused tools that solve specific business problems, integrate with your workflow, and scale as your operations grow.",
  },
];

const processSteps = [
  {
    number: "01",
    title: "Find the friction",
    text: "Identify where time is being lost, where work stalls, and what should be simplified first.",
  },
  {
    number: "02",
    title: "Design the right flow",
    text: "Shape a practical setup that fits the business instead of forcing the business around the tool.",
  },
  {
    number: "03",
    title: "Deliver and refine",
    text: "Build something dependable, useful, and ready to support everyday work with less busywork.",
  },
];
---

<BaseLayout
  title="Home"
  description="Automation Architect helping small businesses simplify repetitive work with AI, automation, and practical software systems."
  locale="en"
  pageKey="home"
>
  <section class="hero" aria-labelledby="hero-title">
    <div class="wrap">
      <p class="eyebrow">Automation Architect &amp; AI Solutions</p>
      <h1 id="hero-title">
        I help small businesses automate repetitive work so their teams can
        focus on what matters most
      </h1>
      <p class="intro">
        I am an Automation Architect and software engineer focused on AI,
        automation, and practical software solutions for small business teams. I
        spot the manual work, design the right system, and build tools your team
        can actually use day to day.
      </p>
      <div class="signal-list" aria-label="Focus areas">
        {
          heroSignals.map((item) => (
            <span class="signal-chip">
              <span aria-hidden="true">{item.symbol}</span>
              {item.label}
            </span>
          ))
        }
      </div>
      <div class="actions">
        <a
          class="cta-primary"
          href="https://calendar.app.google/gcoCqbNkVPxps5ee6"
          target="_blank"
          rel="noreferrer">Schedule a Call</a
        >
        <a class="cta-secondary" href={projectsUrl}>View Projects</a>
      </div>
    </div>
  </section>

  <section class="services wrap" aria-label="Core services">
    <h2 class="section-heading">What I deliver</h2>
    <div class="service-grid">
      {
        services.map((service) => (
          <article class="service">
            <div class="service-icon" aria-hidden="true">
              {service.symbol}
            </div>
            <h3>{service.title}</h3>
            <p>{service.text}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="process wrap" aria-labelledby="process-title">
    <h2 id="process-title" class="section-heading">
      How I usually approach the work
    </h2>
    <div class="process-grid">
      {
        processSteps.map((step) => (
          <article class="step-card">
            <p class="step-number">{step.number}</p>
            <h3>{step.title}</h3>
            <p>{step.text}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="highlight" aria-label="Primary offer summary">
    <div class="wrap">
      <div class="highlight-card">
        <h2>Clear process. Useful systems. Less busywork.</h2>
        <p>
          If parts of your business feel messy, repetitive, or too manual, I can
          help simplify them and build a setup that works better day to day.
        </p>
      </div>
    </div>
  </section>

  <style>
    .hero {
      background: linear-gradient(
        135deg,
        var(--bg-dark) 0%,
        var(--bg-dark-end) 100%
      );
      padding: clamp(2rem, 5vw, 3.5rem) 0 clamp(2.75rem, 6vw, 4.25rem);
      position: relative;
      overflow: hidden;
    }

    .hero .wrap {
      min-height: clamp(14rem, 18vw, 15.5rem);
      display: flex;
      flex-direction: column;
      justify-content: flex-start;
    }

    .hero::before {
      content: "";
      position: absolute;
      inset: 0;
      background:
        radial-gradient(
          circle at 70% 20%,
          rgba(20, 184, 166, 0.12) 0%,
          transparent 50%
        ),
        radial-gradient(
          circle at 20% 80%,
          rgba(20, 184, 166, 0.06) 0%,
          transparent 40%
        );
      pointer-events: none;
    }

    .eyebrow {
      margin: 0;
      color: var(--brand);
      text-transform: uppercase;
      letter-spacing: 0.12em;
      font-size: 0.82rem;
      font-weight: 600;
    }

    h1 {
      margin: 0.55rem 0 0.75rem;
      max-width: 18ch;
      font-size: clamp(1.9rem, 4vw, 2.8rem);
      line-height: 1.1;
      color: var(--ink-light);
      text-wrap: balance;
    }

    .intro {
      max-width: 56ch;
      margin: 0;
      color: var(--muted-light);
      line-height: 1.6;
    }

    .signal-list {
      display: flex;
      flex-wrap: wrap;
      gap: 0.6rem;
      margin-top: 1rem;
    }

    .signal-chip {
      display: inline-flex;
      align-items: center;
      gap: 0.45rem;
      padding: 0.45rem 0.7rem;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.08);
      border: 1px solid rgba(255, 255, 255, 0.1);
      color: var(--ink-light);
      font-size: 0.84rem;
      font-weight: 600;
    }

    .actions {
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem;
      margin-top: 1.4rem;
    }

    .cta-primary,
    .cta-secondary {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 2.9rem;
      border-radius: var(--radius);
      padding: 0 1.25rem;
      font-weight: 600;
      font-size: 0.95rem;
      transition: all var(--transition);
    }

    .cta-primary {
      background: var(--brand);
      color: #fff;
      box-shadow: 0 0 20px rgba(20, 184, 166, 0.3);
    }

    .cta-primary:hover,
    .cta-primary:focus-visible {
      background: var(--brand-dark);
      box-shadow: 0 0 30px rgba(20, 184, 166, 0.45);
      outline: none;
    }

    .cta-secondary {
      border: 1px solid rgba(255, 255, 255, 0.15);
      color: var(--ink-light);
      background: rgba(255, 255, 255, 0.05);
    }

    .cta-secondary:hover,
    .cta-secondary:focus-visible {
      border-color: rgba(255, 255, 255, 0.3);
      background: rgba(255, 255, 255, 0.1);
      outline: none;
    }

    .services {
      padding: 3rem 0 0;
    }

    .section-heading {
      margin: 0 0 1.25rem;
      font-size: 1.35rem;
      color: var(--ink);
    }

    .service-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1rem;
    }

    .service {
      background: var(--surface);
      border: 1px solid var(--stroke);
      border-top: 3px solid var(--brand);
      border-radius: var(--radius-lg);
      padding: 1.25rem;
      transition:
        transform var(--transition),
        box-shadow var(--transition);
    }

    .service:hover {
      transform: translateY(-2px);
      box-shadow: var(--shadow);
    }

    .service-icon {
      display: inline-grid;
      place-items: center;
      width: 2.4rem;
      height: 2.4rem;
      border-radius: 0.8rem;
      background: var(--brand-glow);
      color: var(--brand-dark);
      font-size: 1.1rem;
      margin-bottom: 0.8rem;
    }

    .service h3 {
      margin: 0;
      font-size: 1.05rem;
    }

    .service p {
      margin: 0.6rem 0 0;
      color: var(--muted);
      line-height: 1.6;
      font-size: 0.95rem;
    }

    .process {
      padding-top: 2rem;
    }

    .process-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1rem;
    }

    .step-card {
      background: var(--surface);
      border: 1px solid var(--stroke);
      border-radius: var(--radius-lg);
      padding: 1.25rem;
      box-shadow: var(--shadow-sm);
    }

    .step-number {
      margin: 0;
      color: var(--brand-dark);
      font-family: "Space Grotesk", system-ui, sans-serif;
      font-size: 0.95rem;
      font-weight: 700;
      letter-spacing: 0.08em;
    }

    .step-card h3 {
      margin: 0.4rem 0 0;
      font-size: 1rem;
    }

    .step-card p:last-child {
      margin: 0.55rem 0 0;
      color: var(--muted);
      line-height: 1.6;
    }

    .highlight {
      padding: 2.5rem 0 0;
    }

    .highlight-card {
      background: linear-gradient(
        135deg,
        var(--bg-dark) 0%,
        var(--bg-dark-end) 100%
      );
      border-radius: var(--radius-xl);
      padding: clamp(1.5rem, 3vw, 2.5rem);
      position: relative;
      overflow: hidden;
    }

    .highlight-card::before {
      content: "";
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 3px;
      background: linear-gradient(90deg, var(--brand), transparent);
    }

    .highlight-card h2 {
      margin: 0;
      font-size: clamp(1.15rem, 2vw, 1.35rem);
      color: var(--ink-light);
      text-wrap: balance;
    }

    .highlight-card p {
      margin: 0.6rem 0 0;
      color: var(--muted-light);
      line-height: 1.6;
      max-width: 60ch;
    }

    @media (max-width: 900px) {
      .service-grid,
      .process-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</BaseLayout>
