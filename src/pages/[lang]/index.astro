---
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  buildPageHref,
  getLocaleOrThrow,
  getLocaleStaticPaths,
} from "../../lib/i18n";
import { getCopy } from "../../lib/siteCopy";

export function getStaticPaths() {
  return getLocaleStaticPaths();
}

const locale = getLocaleOrThrow(Astro.params.lang);
const copy = getCopy(locale).home;
const base = import.meta.env.BASE_URL;
const projectsUrl = buildPageHref(base, "projects", locale);
---

<BaseLayout
  title={copy.title}
  description={copy.description}
  locale={locale}
  pageKey="home"
>
  <section class="hero" aria-labelledby="hero-title">
    <div class="wrap">
      <p class="eyebrow">{copy.eyebrow}</p>
      <h1 id="hero-title">{copy.heading}</h1>
      <p class="intro">{copy.intro}</p>
      <div class="signal-list" aria-label="Focus areas">
        {
          copy.heroSignals.map((item) => (
            <span class="signal-chip">
              <span aria-hidden="true">{item.symbol}</span>
              {item.label}
            </span>
          ))
        }
      </div>
      <div class="actions">
        <a
          class="cta-primary"
          href="https://calendar.app.google/gcoCqbNkVPxps5ee6"
          target="_blank"
          rel="noreferrer">{copy.primaryCta}</a
        >
        <a class="cta-secondary" href={projectsUrl}>{copy.secondaryCta}</a>
      </div>
    </div>
  </section>

  <section class="services wrap" aria-label="Core services">
    <h2 class="section-heading">{copy.sectionHeading}</h2>
    <div class="service-grid">
      {
        copy.services.map((service) => (
          <article class="service">
            <div class="service-icon" aria-hidden="true">
              {service.symbol}
            </div>
            <h3>{service.title}</h3>
            <p>{service.text}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="process wrap" aria-labelledby="process-title">
    <h2 id="process-title" class="section-heading">{copy.processHeading}</h2>
    <div class="process-grid">
      {
        copy.processSteps.map((step) => (
          <article class="step-card">
            <p class="step-number">{step.number}</p>
            <h3>{step.title}</h3>
            <p>{step.text}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="highlight" aria-label="Primary offer summary">
    <div class="wrap">
      <div class="highlight-card">
        <h2>{copy.highlightTitle}</h2>
        <p>{copy.highlightText}</p>
      </div>
    </div>
  </section>

  <style>
    .hero {
      background: linear-gradient(
        135deg,
        var(--bg-dark) 0%,
        var(--bg-dark-end) 100%
      );
      padding: clamp(2rem, 5vw, 3.5rem) 0 clamp(2.75rem, 6vw, 4.25rem);
      position: relative;
      overflow: hidden;
    }

    .hero .wrap {
      min-height: clamp(14rem, 18vw, 15.5rem);
      display: flex;
      flex-direction: column;
      justify-content: flex-start;
    }

    .hero::before {
      content: "";
      position: absolute;
      inset: 0;
      background:
        radial-gradient(
          circle at 70% 20%,
          rgba(20, 184, 166, 0.12) 0%,
          transparent 50%
        ),
        radial-gradient(
          circle at 20% 80%,
          rgba(20, 184, 166, 0.06) 0%,
          transparent 40%
        );
      pointer-events: none;
    }

    .eyebrow {
      margin: 0;
      color: var(--brand);
      text-transform: uppercase;
      letter-spacing: 0.12em;
      font-size: 0.82rem;
      font-weight: 600;
    }

    h1 {
      margin: 0.55rem 0 0.75rem;
      max-width: 18ch;
      font-size: clamp(1.9rem, 4vw, 2.8rem);
      line-height: 1.1;
      color: var(--ink-light);
      text-wrap: balance;
    }

    .intro {
      max-width: 56ch;
      margin: 0;
      color: var(--muted-light);
      line-height: 1.6;
    }

    .signal-list {
      display: flex;
      flex-wrap: wrap;
      gap: 0.6rem;
      margin-top: 1rem;
    }

    .signal-chip {
      display: inline-flex;
      align-items: center;
      gap: 0.45rem;
      padding: 0.45rem 0.7rem;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.08);
      border: 1px solid rgba(255, 255, 255, 0.1);
      color: var(--ink-light);
      font-size: 0.84rem;
      font-weight: 600;
    }

    .actions {
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem;
      margin-top: 1.4rem;
    }

    .cta-primary,
    .cta-secondary {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 2.9rem;
      border-radius: var(--radius);
      padding: 0 1.25rem;
      font-weight: 600;
      font-size: 0.95rem;
      transition: all var(--transition);
    }

    .cta-primary {
      background: var(--brand);
      color: #fff;
      box-shadow: 0 0 20px rgba(20, 184, 166, 0.3);
    }

    .cta-primary:hover,
    .cta-primary:focus-visible {
      background: var(--brand-dark);
      box-shadow: 0 0 30px rgba(20, 184, 166, 0.45);
      outline: none;
    }

    .cta-secondary {
      border: 1px solid rgba(255, 255, 255, 0.15);
      color: var(--ink-light);
      background: rgba(255, 255, 255, 0.05);
    }

    .cta-secondary:hover,
    .cta-secondary:focus-visible {
      border-color: rgba(255, 255, 255, 0.3);
      background: rgba(255, 255, 255, 0.1);
      outline: none;
    }

    .services,
    .process,
    .highlight {
      padding-top: 2rem;
    }

    .section-heading {
      margin: 0 0 1rem;
      font-size: 1.35rem;
    }

    .service-grid,
    .process-grid {
      display: grid;
      gap: 1rem;
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .service,
    .step-card {
      border: 1px solid var(--stroke);
      border-top: 3px solid var(--brand);
      border-radius: var(--radius-lg);
      background: var(--surface);
      padding: 1.25rem;
      box-shadow: var(--shadow-sm);
    }

    .service-icon {
      display: inline-grid;
      place-items: center;
      width: 2.2rem;
      height: 2.2rem;
      border-radius: 0.75rem;
      background: var(--brand-glow);
      color: var(--brand-dark);
      font-size: 1rem;
      margin-bottom: 0.8rem;
    }

    .service h3,
    .step-card h3 {
      margin: 0;
      font-size: 1rem;
    }

    .service p,
    .step-card p,
    .highlight-card p {
      color: var(--muted);
      line-height: 1.6;
    }

    .step-number {
      margin: 0 0 0.35rem;
      color: var(--brand-dark) !important;
      font-weight: 700;
      letter-spacing: 0.06em;
      text-transform: uppercase;
    }

    .highlight-card {
      background: linear-gradient(
        135deg,
        var(--bg-dark) 0%,
        var(--bg-dark-end) 100%
      );
      border-radius: var(--radius-xl);
      padding: clamp(1.5rem, 3vw, 2.5rem);
      position: relative;
      overflow: hidden;
    }

    .highlight-card::before {
      content: "";
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 3px;
      background: linear-gradient(90deg, var(--brand), transparent);
    }

    .highlight-card h2 {
      margin: 0;
      color: var(--ink-light);
      font-size: 1.25rem;
    }

    .highlight-card p {
      margin: 0.65rem 0 0;
      color: var(--muted-light);
      max-width: 60ch;
    }

    @media (max-width: 900px) {
      .service-grid,
      .process-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</BaseLayout>
