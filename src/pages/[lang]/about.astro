---
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  buildPageHref,
  getLocaleOrThrow,
  getLocaleStaticPaths,
} from "../../lib/i18n";
import { getCopy } from "../../lib/siteCopy";

export function getStaticPaths() {
  return getLocaleStaticPaths();
}

const locale = getLocaleOrThrow(Astro.params.lang);
const copy = getCopy(locale).about;
const base = import.meta.env.BASE_URL;
const contactUrl = buildPageHref(base, "contact", locale);
const linkedinUrl =
  "https://linkedin.com/in/ant%C3%B3nio-eleut%C3%A9rio-%F0%9F%87%AA%F0%9F%87%BA-02980145";
---

<BaseLayout
  title={copy.title}
  description={copy.description}
  locale={locale}
  pageKey="about"
>
  <div class="page-header">
    <div class="wrap">
      <p class="eyebrow">{copy.eyebrow}</p>
      <h1>{copy.heading}</h1>
      <p class="header-desc">{copy.headerDesc}</p>
    </div>
  </div>

  <div class="wrap page-body">
    <section class="intro-grid" aria-label="About overview">
      <article class="story-card story-card--lead">
        <h2>{copy.howIWorkTitle}</h2>
        {copy.howIWork.map((paragraph) => <p>{paragraph}</p>)}
      </article>

      <article class="story-card story-card--profile">
        <h2>{copy.profileTitle}</h2>
        <ul class="fact-list">
          {
            copy.profileFacts.map((fact) => (
              <li>
                <span class="symbol-badge" aria-hidden="true">
                  {fact.symbol}
                </span>
                <span>{fact.text}</span>
              </li>
            ))
          }
        </ul>
        <a class="cta-link" href={linkedinUrl} target="_blank" rel="noreferrer"
          >{copy.profileLink}</a
        >
      </article>
    </section>

    <section class="highlights" aria-labelledby="strengths-title">
      <h2 id="strengths-title">{copy.strengthsTitle}</h2>
      <div class="highlight-grid">
        {
          copy.highlights.map((item) => (
            <article class="highlight-card">
              <div class="highlight-symbol" aria-hidden="true">
                {item.symbol}
              </div>
              <h3>{item.title}</h3>
              <p>{item.text}</p>
            </article>
          ))
        }
      </div>
    </section>

    <section class="journey" aria-labelledby="journey-title">
      <div class="journey-card">
        <h2 id="journey-title">{copy.journeyTitle}</h2>
        <div class="timeline">
          {
            copy.timeline.map((item) => (
              <article class="timeline-item">
                <p class="timeline-period">{item.period}</p>
                <h3>{item.role}</h3>
                <p>{item.summary}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="focus" aria-labelledby="focus-title">
      <div class="focus-card">
        <h2 id="focus-title">{copy.focusTitle}</h2>
        <p>{copy.focusText}</p>
      </div>
    </section>

    <section class="personal" aria-labelledby="personal-title">
      <article class="story-card">
        <h2 id="personal-title">{copy.personalTitle}</h2>
        <p>{copy.personalText}</p>
        <ul class="interest-list">
          {copy.interests.map((interest) => <li>{interest}</li>)}
        </ul>
        <a class="text-link" href={contactUrl}>{copy.personalLink}</a>
      </article>
    </section>
  </div>

  <style>
    .page-header {
      background: linear-gradient(
        135deg,
        var(--bg-dark) 0%,
        var(--bg-dark-end) 100%
      );
      padding: clamp(2rem, 5vw, 3.5rem) 0;
      position: relative;
      overflow: hidden;
    }

    .page-header::before {
      content: "";
      position: absolute;
      inset: 0;
      background:
        radial-gradient(
          circle at 78% 28%,
          rgba(20, 184, 166, 0.12) 0%,
          transparent 50%
        ),
        radial-gradient(
          circle at 15% 85%,
          rgba(20, 184, 166, 0.07) 0%,
          transparent 40%
        );
      pointer-events: none;
    }

    .page-header .wrap {
      min-height: clamp(14rem, 18vw, 15.5rem);
      display: flex;
      flex-direction: column;
      justify-content: flex-start;
    }

    .eyebrow {
      margin: 0;
      color: var(--brand);
      text-transform: uppercase;
      letter-spacing: 0.12em;
      font-size: 0.82rem;
      font-weight: 600;
    }

    h1 {
      margin: 0.55rem 0 0.75rem;
      max-width: 18ch;
      font-size: clamp(1.9rem, 4vw, 2.8rem);
      line-height: 1.1;
      text-wrap: balance;
      color: var(--ink-light);
    }

    .header-desc {
      max-width: 60ch;
      margin: 0;
      color: var(--muted-light);
      line-height: 1.6;
    }

    .page-body {
      padding-top: 2rem;
    }

    .intro-grid,
    .highlight-grid {
      display: grid;
      gap: 1rem;
    }

    .intro-grid {
      grid-template-columns: 1.5fr 1fr;
      align-items: stretch;
    }

    .story-card,
    .highlight-card {
      background: var(--surface);
      border: 1px solid var(--stroke);
      border-top: 3px solid var(--brand);
      border-radius: var(--radius-lg);
      padding: 1.25rem;
      box-shadow: var(--shadow-sm);
    }

    .story-card h2,
    .highlights h2,
    .journey-card h2,
    .focus-card h2 {
      margin: 0;
      font-size: 1.2rem;
    }

    .story-card p,
    .highlight-card p,
    .timeline-item p,
    .focus-card p {
      color: var(--muted);
      line-height: 1.6;
    }

    .story-card p + p {
      margin-top: 0.8rem;
    }

    .story-card--profile {
      background: linear-gradient(
        135deg,
        rgba(15, 23, 42, 0.98) 0%,
        rgba(30, 41, 59, 0.98) 100%
      );
      border-color: transparent;
    }

    .story-card--profile h2 {
      color: var(--ink-light);
    }

    .fact-list {
      list-style: none;
      margin: 0.9rem 0 0;
      padding: 0;
      color: var(--muted-light);
    }

    .fact-list li {
      display: flex;
      align-items: flex-start;
      gap: 0.6rem;
      line-height: 1.65;
    }

    .fact-list li + li {
      margin-top: 0.5rem;
    }

    .symbol-badge {
      display: inline-grid;
      place-items: center;
      width: 1.6rem;
      height: 1.6rem;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.08);
      color: var(--brand);
      flex-shrink: 0;
    }

    .cta-link {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 2.6rem;
      margin-top: 1rem;
      padding: 0 1rem;
      border-radius: var(--radius);
      background: var(--brand);
      color: #fff;
      font-weight: 600;
      transition: all var(--transition);
    }

    .cta-link:hover,
    .cta-link:focus-visible {
      background: var(--brand-dark);
      outline: none;
    }

    .highlights,
    .journey,
    .focus,
    .personal {
      margin-top: 2rem;
    }

    .highlights h2 {
      margin-bottom: 1rem;
    }

    .highlight-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .highlight-symbol {
      display: inline-grid;
      place-items: center;
      width: 2.2rem;
      height: 2.2rem;
      border-radius: 0.75rem;
      background: var(--brand-glow);
      color: var(--brand-dark);
      font-size: 1rem;
      margin-bottom: 0.8rem;
    }

    .highlight-card h3,
    .timeline-item h3 {
      margin: 0;
      font-size: 1rem;
    }

    .highlight-card p {
      margin: 0.6rem 0 0;
    }

    .journey-card,
    .focus-card {
      background: linear-gradient(
        135deg,
        var(--bg-dark) 0%,
        var(--bg-dark-end) 100%
      );
      border-radius: var(--radius-xl);
      padding: clamp(1.5rem, 3vw, 2.25rem);
      position: relative;
      overflow: hidden;
    }

    .journey-card::before,
    .focus-card::before {
      content: "";
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 3px;
      background: linear-gradient(90deg, var(--brand), transparent);
    }

    .journey-card h2,
    .focus-card h2 {
      color: var(--ink-light);
    }

    .timeline {
      display: grid;
      gap: 0.9rem;
      margin-top: 1rem;
    }

    .timeline-item {
      padding: 1rem;
      border-radius: var(--radius-lg);
      background: rgba(255, 255, 255, 0.06);
      border: 1px solid rgba(255, 255, 255, 0.08);
    }

    .timeline-item p {
      margin: 0.45rem 0 0;
      color: var(--muted-light);
    }

    .timeline-period {
      margin: 0;
      color: var(--brand) !important;
      font-size: 0.8rem;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .focus-card p {
      max-width: 64ch;
      margin: 0.7rem 0 0;
      color: var(--muted-light);
    }

    .interest-list {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      list-style: none;
      padding: 0;
      margin: 1rem 0 0;
    }

    .interest-list li {
      padding: 0.45rem 0.7rem;
      border-radius: 999px;
      background: var(--brand-glow);
      color: var(--brand-dark);
      font-size: 0.88rem;
      font-weight: 600;
    }

    .text-link {
      display: inline-block;
      margin-top: 1rem;
      color: var(--brand-dark);
      font-weight: 600;
    }

    .text-link:hover,
    .text-link:focus-visible {
      text-decoration: underline;
      outline: none;
    }

    @media (max-width: 900px) {
      .intro-grid,
      .highlight-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</BaseLayout>
