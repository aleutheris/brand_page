---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { getCopy } from "../../lib/siteCopy";
import {
  getLocaleOrThrow,
  getLocaleStaticPaths,
  buildPageHref,
} from "../../lib/i18n";

export function getStaticPaths() {
  return getLocaleStaticPaths();
}

const locale = getLocaleOrThrow(Astro.params.lang);
const reviews = (await getCollection("reviews"))
  .sort((a, b) => a.data.order - b.data.order)
  .map(({ id, data }) => ({ id, ...data }));

const copy = getCopy(locale);
const base = import.meta.env.BASE_URL;
const contactUrl = buildPageHref(base, "contact", locale);
---

<BaseLayout
  title={copy.reviews.title}
  description={copy.reviews.description}
  locale={locale}
  pageKey="reviews"
>
  <div class="page-header">
    <div class="wrap">
      <p class="eyebrow">{copy.reviews.eyebrow}</p>
      <h1 id="reviews-title">{copy.reviews.heading}</h1>
      <p class="header-desc">{copy.reviews.headerDesc}</p>
    </div>
  </div>

  <div class="wrap">
    <section aria-label="Review cards" class="cards">
      {
        reviews.map((review) => (
          <article class="card">
            <blockquote class="review-text">"{review.reviewText}"</blockquote>
            <cite class="reviewer">— {review.reviewerName}</cite>
            {review.projectRef && (
              <p class="project-ref">Project: {review.projectRef}</p>
            )}
          </article>
        ))
      }
    </section>

    <section class="cta-section">
      <h2>{copy.reviews.ctaTitle}</h2>
      <p>{copy.reviews.ctaText}</p>
      <a href={contactUrl} class="cta-button">{copy.reviews.ctaLink}</a>
    </section>
  </div>
</BaseLayout>
