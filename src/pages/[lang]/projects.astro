---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { getLocaleOrThrow, getLocaleStaticPaths } from "../../lib/i18n";
import { getCopy } from "../../lib/siteCopy";

export function getStaticPaths() {
  return getLocaleStaticPaths();
}

const locale = getLocaleOrThrow(Astro.params.lang);
const copy = getCopy(locale).projects;

const projects = (await getCollection("projects"))
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 1)
  .map(({ id, data }) => {
    const translated = copy.entries[id as keyof typeof copy.entries] ?? {};
    return {
      id,
      ...data,
      ...translated,
      expectedBenefits:
        translated.expectedBenefits ??
        data.expectedBenefits ??
        data.observedOutcome,
    };
  });
---

<BaseLayout
  title={copy.title}
  description={copy.description}
  locale={locale}
  pageKey="projects"
>
  <div class="page-header">
    <div class="wrap">
      <p class="eyebrow">{copy.eyebrow}</p>
      <h1 id="projects-title">{copy.heading}</h1>
      <p class="header-desc">{copy.headerDesc}</p>
      <div class="stage-strip" aria-label="Project flow overview">
        {
          copy.stages.map((stage) => (
            <span class="stage-chip">
              <span class="stage-symbol">{stage.symbol}</span>
              {stage.label}
            </span>
          ))
        }
      </div>
    </div>
  </div>

  <div class="wrap">
    <section aria-label="Project cards" class="cards">
      {
        projects.map((project) => (
          <article class="card" aria-labelledby={`${project.id}-title`}>
            <h2 id={`${project.id}-title`}>{project.title}</h2>

            <p class="label">
              <span class="label-icon">◇</span>
              {copy.labels.problem}
            </p>
            <p>{project.businessProblem}</p>

            <p class="label">
              <span class="label-icon">⚙</span>
              {copy.labels.solution}
            </p>
            <p>{project.deliveredSolution}</p>

            <p class="label">
              <span class="label-icon">↗</span>
              {copy.labels.benefits}
            </p>
            <p>{project.expectedBenefits}</p>

            {project.nextPhase && (
              <>
                <p class="label">
                  <span class="label-icon">✦</span>
                  {copy.labels.nextPhase}
                </p>
                <p>{project.nextPhase}</p>
              </>
            )}
          </article>
        ))
      }
    </section>

    <section class="next-step" aria-label="Contact call to action">
      <div class="next-step-card">
        <h2>{copy.ctaTitle}</h2>
        <p>{copy.ctaText}</p>
        <a
          href="https://calendar.app.google/gcoCqbNkVPxps5ee6"
          target="_blank"
          rel="noreferrer">{copy.ctaLink}</a
        >
      </div>
    </section>
  </div>

  <style>
    .page-header {
      background: linear-gradient(
        135deg,
        var(--bg-dark) 0%,
        var(--bg-dark-end) 100%
      );
      padding: clamp(2rem, 5vw, 3.5rem) 0;
      position: relative;
    }

    .page-header .wrap {
      min-height: clamp(14rem, 18vw, 15.5rem);
      display: flex;
      flex-direction: column;
      justify-content: flex-start;
    }

    .page-header::before {
      content: "";
      position: absolute;
      inset: 0;
      background: radial-gradient(
        circle at 80% 30%,
        rgba(20, 184, 166, 0.1) 0%,
        transparent 50%
      );
      pointer-events: none;
    }

    .eyebrow {
      margin: 0;
      color: var(--brand);
      text-transform: uppercase;
      letter-spacing: 0.12em;
      font-size: 0.82rem;
      font-weight: 600;
    }

    h1 {
      margin: 0.55rem 0 0.75rem;
      max-width: 18ch;
      font-size: clamp(1.9rem, 4vw, 2.8rem);
      line-height: 1.1;
      text-wrap: balance;
      color: var(--ink-light);
    }

    .header-desc {
      max-width: 56ch;
      margin: 0;
      color: var(--muted-light);
      line-height: 1.6;
    }

    .stage-strip {
      display: flex;
      flex-wrap: wrap;
      gap: 0.6rem;
      margin-top: 1rem;
    }

    .stage-chip {
      display: inline-flex;
      align-items: center;
      gap: 0.45rem;
      padding: 0.45rem 0.7rem;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.08);
      border: 1px solid rgba(255, 255, 255, 0.1);
      color: var(--ink-light);
      font-size: 0.84rem;
      font-weight: 600;
    }

    .stage-symbol {
      color: var(--brand);
      font-family: "Space Grotesk", system-ui, sans-serif;
    }

    .cards {
      display: grid;
      gap: 1rem;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      margin-top: 2rem;
    }

    .card {
      border: 1px solid var(--stroke);
      border-top: 3px solid var(--brand);
      border-radius: var(--radius-lg);
      background: var(--surface);
      padding: 1.25rem;
      transition:
        transform var(--transition),
        box-shadow var(--transition);
    }

    .card:hover {
      transform: translateY(-2px);
      box-shadow: var(--shadow);
    }

    .card h2 {
      margin: 0;
      font-size: 1.15rem;
      text-wrap: balance;
    }

    .card p {
      margin: 0.35rem 0 0;
      color: var(--muted);
      line-height: 1.55;
    }

    .label {
      display: flex;
      align-items: center;
      gap: 0.4rem;
      margin-top: 0.75rem;
      color: var(--ink);
      font-weight: 700;
      font-size: 0.82rem;
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }

    .label-icon {
      color: var(--brand-dark);
      font-size: 0.95rem;
    }

    .next-step {
      margin-top: 2rem;
    }

    .next-step-card {
      background: linear-gradient(
        135deg,
        var(--bg-dark) 0%,
        var(--bg-dark-end) 100%
      );
      border-radius: var(--radius-xl);
      padding: clamp(1.5rem, 3vw, 2.5rem);
      position: relative;
      overflow: hidden;
    }

    .next-step-card::before {
      content: "";
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 3px;
      background: linear-gradient(90deg, var(--brand), transparent);
    }

    .next-step-card h2 {
      margin: 0;
      font-size: 1.25rem;
      color: var(--ink-light);
    }

    .next-step-card p {
      margin: 0.5rem 0 1rem;
      max-width: 62ch;
      color: var(--muted-light);
      line-height: 1.55;
    }

    .next-step-card a {
      display: inline-flex;
      min-height: 2.8rem;
      align-items: center;
      justify-content: center;
      border-radius: var(--radius);
      padding: 0 1.25rem;
      font-weight: 600;
      background: var(--brand);
      color: #fff;
      box-shadow: 0 0 20px rgba(20, 184, 166, 0.3);
      transition: all var(--transition);
    }

    .next-step-card a:hover,
    .next-step-card a:focus-visible {
      background: var(--brand-dark);
      box-shadow: 0 0 30px rgba(20, 184, 166, 0.45);
      outline: none;
    }
  </style>
</BaseLayout>
