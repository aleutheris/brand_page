---
import BaseLayout from "../layouts/BaseLayout.astro";

const linkedinUrl =
  "https://linkedin.com/in/ant%C3%B3nio-eleut%C3%A9rio-%F0%9F%87%AA%F0%9F%87%BA-02980145";
---

<BaseLayout title="Contact">
  <div class="page-header">
    <div class="wrap">
      <p class="eyebrow">Get in touch</p>
      <h1 id="contact-title">Let's talk about what you'd like to automate</h1>
      <p class="header-desc">
        If you are dealing with repetitive work, messy handoffs, or processes
        that should be simpler, feel free to reach out. I work directly with
        businesses and can also support existing teams when needed.
      </p>
    </div>
  </div>

  <div class="wrap">
    <section class="channels" aria-label="Contact channels">
      <article class="channel">
        <h2>Email</h2>
        <p>
          Send a few lines about your business, the repetitive work you want to
          reduce, or the kind of system you want to improve.
        </p>
        <a href="mailto:info@aleutheris.com">info@aleutheris.com</a>
      </article>

      <article class="channel">
        <h2>LinkedIn</h2>
        <p>
          If you prefer, you can also connect with me there and get a broader
          view of my professional background.
        </p>
        <a href={linkedinUrl} target="_blank" rel="noreferrer">View LinkedIn</a>
      </article>

      <article class="channel">
        <h2>Schedule a Call</h2>
        <p>
          If you would rather talk it through first, send me a quick note and we
          can set up a short call.
        </p>
        <a
          href="https://calendar.app.google/gcoCqbNkVPxps5ee6"
          target="_blank"
          rel="noreferrer">Schedule a call</a
        >
      </article>
    </section>

    <section class="expectation" aria-label="Response expectations">
      <div class="expectation-card">
        <h2>Response expectation</h2>
        <p>
          I usually reply within one business day. Timezone: CEST. Languages:
          Portuguese and English.
        </p>
      </div>
    </section>
  </div>

  <style>
    .page-header {
      background: linear-gradient(
        135deg,
        var(--bg-dark) 0%,
        var(--bg-dark-end) 100%
      );
      padding: clamp(2rem, 5vw, 3.5rem) 0;
      position: relative;
    }

    .page-header .wrap {
      min-height: clamp(14rem, 18vw, 15.5rem);
      display: flex;
      flex-direction: column;
      justify-content: flex-start;
    }

    .page-header::before {
      content: "";
      position: absolute;
      inset: 0;
      background: radial-gradient(
        circle at 80% 30%,
        rgba(20, 184, 166, 0.1) 0%,
        transparent 50%
      );
      pointer-events: none;
    }

    .eyebrow {
      margin: 0;
      color: var(--brand);
      text-transform: uppercase;
      letter-spacing: 0.12em;
      font-size: 0.82rem;
      font-weight: 600;
    }

    h1 {
      margin: 0.55rem 0 0.75rem;
      max-width: 18ch;
      font-size: clamp(1.9rem, 4vw, 2.8rem);
      line-height: 1.1;
      text-wrap: balance;
      color: var(--ink-light);
    }

    .header-desc {
      max-width: 58ch;
      margin: 0;
      color: var(--muted-light);
      line-height: 1.6;
    }

    .channels {
      margin-top: 2rem;
      display: grid;
      gap: 1rem;
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .channel {
      border: 1px solid var(--stroke);
      border-top: 3px solid var(--brand);
      border-radius: var(--radius-lg);
      background: var(--surface);
      padding: 1.25rem;
      transition:
        transform var(--transition),
        box-shadow var(--transition);
    }

    .channel:hover {
      transform: translateY(-2px);
      box-shadow: var(--shadow);
    }

    .channel h2 {
      margin: 0;
      font-size: 1.1rem;
    }

    .channel p {
      margin: 0.6rem 0 0.8rem;
      color: var(--muted);
      line-height: 1.55;
    }

    .channel a {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 2.6rem;
      border-radius: var(--radius);
      padding: 0 1rem;
      font-weight: 600;
      background: var(--brand);
      color: #fff;
      box-shadow: 0 0 20px rgba(20, 184, 166, 0.3);
      transition: all var(--transition);
    }

    .channel a:hover,
    .channel a:focus-visible {
      background: var(--brand-dark);
      box-shadow: 0 0 30px rgba(20, 184, 166, 0.45);
      outline: none;
    }

    .expectation {
      margin-top: 2rem;
    }

    .expectation-card {
      background: linear-gradient(
        135deg,
        var(--bg-dark) 0%,
        var(--bg-dark-end) 100%
      );
      border-radius: var(--radius-xl);
      padding: clamp(1.5rem, 3vw, 2.5rem);
      position: relative;
      overflow: hidden;
    }

    .expectation-card::before {
      content: "";
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 3px;
      background: linear-gradient(90deg, var(--brand), transparent);
    }

    .expectation-card h2 {
      margin: 0;
      font-size: 1.2rem;
      color: var(--ink-light);
    }

    .expectation-card p {
      margin: 0.5rem 0 0;
      max-width: 62ch;
      color: var(--muted-light);
      line-height: 1.55;
    }

    @media (max-width: 900px) {
      .channels {
        grid-template-columns: 1fr;
      }
    }
  </style>
</BaseLayout>
