---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <style>
      :root {
        --bg: #f4efe7;
        --surface: #fffaf3;
        --ink: #21201e;
        --muted: #5e5a53;
        --brand: #0f766e;
        --brand-dark: #115e59;
        --stroke: #d9d0c3;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        color: var(--ink);
        font-family: "Space Grotesk", "Manrope", sans-serif;
        background:
          radial-gradient(circle at 10% 0%, #fff6d9 0%, transparent 32%),
          radial-gradient(circle at 100% 10%, #d8f5ef 0%, transparent 25%),
          var(--bg);
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      header {
        position: sticky;
        top: 0;
        z-index: 10;
        backdrop-filter: blur(4px);
        background: color-mix(in srgb, var(--bg), transparent 22%);
        border-bottom: 1px solid var(--stroke);
      }

      nav {
        display: flex;
        gap: 1rem;
        width: min(1080px, 92vw);
        margin: 0 auto;
        padding: 0.95rem 0;
      }

      nav a {
        font-weight: 700;
        letter-spacing: 0.01em;
        padding: 0.45rem 0.65rem;
        border-radius: 0.6rem;
      }

      nav a:hover,
      nav a:focus-visible {
        background: color-mix(in srgb, var(--brand), white 86%);
        outline: none;
      }

      main {
        width: min(1080px, 92vw);
        margin: 2.6rem auto 3.5rem;
      }

      @media (max-width: 640px) {
        nav {
          justify-content: space-between;
          gap: 0.4rem;
          font-size: 0.92rem;
        }
      }
    </style>
  </head>
  <body>
    <header>
      <nav aria-label="Primary navigation">
        <a href="/">Home</a>
        <a href="/projects">Projects</a>
        <a href="/contact">Contact</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
  </body>
</html>
