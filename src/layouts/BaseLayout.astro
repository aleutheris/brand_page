---
import { withBase } from "../lib/withBase";
import {
  buildPageHref,
  defaultLocale,
  getCurrentLocaleMode,
  localeMeta,
  locales,
  navCopy,
  normalizePath,
  type Locale,
  type PageKey,
} from "../lib/i18n";

interface Props {
  title: string;
  description?: string;
  image?: string;
  locale?: Locale;
  pageKey?: PageKey;
}

const base = import.meta.env.BASE_URL;
const {
  title,
  description = "Automation Architect helping small businesses simplify operations with AI, automation, and practical software solutions.",
  image = withBase(base, "images/og-preview.png"),
  locale = defaultLocale,
  pageKey = "home",
} = Astro.props;

const logoUrl = withBase(base, "images/logo_with_name.png");
const siteUrl = Astro.site ?? new URL("https://aleutheris.com");
const currentPath = Astro.url.pathname;
const { useExplicitEnglish } = getCurrentLocaleMode(currentPath, base);
const navLabels = navCopy[locale];

const homeUrl = buildPageHref(base, "home", locale, {
  forcePrefix: useExplicitEnglish,
});
const projectsUrl = buildPageHref(base, "projects", locale, {
  forcePrefix: useExplicitEnglish,
});
const aboutUrl = buildPageHref(base, "about", locale, {
  forcePrefix: useExplicitEnglish,
});
const reviewsUrl = buildPageHref(base, "reviews", locale, {
  forcePrefix: useExplicitEnglish,
});
const contactUrl = buildPageHref(base, "contact", locale, {
  forcePrefix: useExplicitEnglish,
});

const canonicalUrl = new URL(
  buildPageHref(base, pageKey, locale, {
    forcePrefix: locale !== defaultLocale,
  }),
  siteUrl,
).toString();
const alternateLinks = locales.map((item) => ({
  locale: item,
  href: new URL(
    buildPageHref(base, pageKey, item, { forcePrefix: item !== defaultLocale }),
    siteUrl,
  ).toString(),
}));
const languageLinks = locales.map((item) => ({
  code: item,
  href: buildPageHref(base, pageKey, item, {
    forcePrefix: item !== defaultLocale || useExplicitEnglish,
  }),
  label: localeMeta[item].label,
  name: localeMeta[item].name,
  isCurrent: item === locale,
}));
const ogImageUrl = new URL(image, siteUrl).toString();
const pageTitle =
  pageKey === "home"
    ? `António Eleutério | ${navLabels.siteTagline}`
    : `${title} | António Eleutério`;

function isActivePath(path: string) {
  return normalizePath(currentPath) === normalizePath(path);
}
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index,follow" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="x-default" href={alternateLinks[0].href} />
    {
      alternateLinks.map((link) => (
        <link rel="alternate" hreflang={link.locale} href={link.href} />
      ))
    }
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="António Eleutério" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content={localeMeta[locale].ogLocale} />
    {
      locales
        .filter((item) => item !== locale)
        .map((item) => (
          <meta
            property="og:locale:alternate"
            content={localeMeta[item].ogLocale}
          />
        ))
    }
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <link
      rel="icon"
      type="image/png"
      href={withBase(base, "images/logo_square.png")}
    />
    <link
      rel="apple-touch-icon"
      href={withBase(base, "images/logo_square.png")}
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Space+Grotesk:wght@500;600;700&display=swap"
      rel="stylesheet"
    />
    <script
      is:inline
      id="vtag-ai-js"
      async
      src="https://r2.leadsy.ai/tag.js"
      data-pid="aHlLZOTYZ1h29QDb"
      data-version="062024"></script>
    <style is:global>
      :root {
        --bg: #f8fafc;
        --bg-dark: #0f172a;
        --bg-dark-end: #1e293b;
        --surface: #ffffff;
        --ink: #0f172a;
        --ink-light: #f1f5f9;
        --muted: #64748b;
        --muted-light: #94a3b8;
        --brand: #14b8a6;
        --brand-dark: #0d9488;
        --brand-glow: rgba(20, 184, 166, 0.15);
        --stroke: #e2e8f0;
        --radius: 0.75rem;
        --radius-lg: 1rem;
        --radius-xl: 1.25rem;
        --shadow-sm: 0 1px 3px rgba(0, 0, 0, 0.05);
        --shadow: 0 4px 16px rgba(0, 0, 0, 0.06);
        --shadow-lg: 0 12px 40px rgba(0, 0, 0, 0.1);
        --transition: 0.2s ease;
        --max-w: min(1120px, 92vw);
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
        overflow-y: scroll;
        scrollbar-gutter: stable;
      }

      body {
        margin: 0;
        color: var(--ink);
        font-family: "Inter", system-ui, sans-serif;
        background: var(--bg);
        -webkit-font-smoothing: antialiased;
      }

      h1,
      h2,
      h3,
      h4 {
        font-family: "Space Grotesk", system-ui, sans-serif;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      img {
        max-width: 100%;
        height: auto;
      }

      .wrap {
        width: var(--max-w);
        margin-inline: auto;
      }
    </style>
  </head>
  <body>
    <header>
      <nav aria-label="Primary navigation">
        <a href={homeUrl} class="nav-brand">
          <img src={logoUrl} alt="" class="logo" />
        </a>
        <div class="nav-tools">
          <div class="nav-links">
            <a
              href={homeUrl}
              aria-current={isActivePath(homeUrl) ? "page" : undefined}
              >{navLabels.home}</a
            >
            <a
              href={projectsUrl}
              aria-current={isActivePath(projectsUrl) ? "page" : undefined}
              >{navLabels.projects}</a
            >
            <a
              href={aboutUrl}
              aria-current={isActivePath(aboutUrl) ? "page" : undefined}
              >{navLabels.about}</a
            >
            <a
              href={reviewsUrl}
              aria-current={isActivePath(reviewsUrl) ? "page" : undefined}
              >{navLabels.reviews}</a
            >
            <a
              href={contactUrl}
              aria-current={isActivePath(contactUrl) ? "page" : undefined}
              >{navLabels.contact}</a
            >
          </div>
          <div class="language-switcher" aria-label={navLabels.language}>
            {
              languageLinks.map((item) => (
                <a
                  href={item.href}
                  lang={item.code}
                  hreflang={item.code}
                  title={item.name}
                  aria-current={item.isCurrent ? "true" : undefined}
                >
                  {item.label}
                </a>
              ))
            }
          </div>
        </div>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <div class="wrap">
        <p>&copy; {new Date().getFullYear()} &middot; {navLabels.footer}</p>
      </div>
    </footer>
    <style>
      header {
        position: sticky;
        top: 0;
        z-index: 50;
        backdrop-filter: blur(14px) saturate(1.6);
        -webkit-backdrop-filter: blur(14px) saturate(1.6);
        background: rgba(248, 250, 252, 0.82);
        border-bottom: 1px solid var(--stroke);
      }

      nav {
        display: flex;
        align-items: center;
        width: var(--max-w);
        margin: 0 auto;
        padding: 0.7rem 0;
        gap: 1.25rem;
      }

      .nav-brand {
        display: flex;
        flex-shrink: 0;
      }

      .logo {
        height: 2rem;
        width: auto;
      }

      .nav-tools {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        margin-left: auto;
        flex-wrap: wrap;
        justify-content: flex-end;
      }

      .nav-links {
        display: flex;
        gap: 0.15rem;
      }

      .nav-links a {
        font-family: "Space Grotesk", system-ui, sans-serif;
        font-weight: 600;
        font-size: 0.9rem;
        padding: 0.45rem 0.7rem;
        border-radius: var(--radius);
        transition:
          background var(--transition),
          color var(--transition);
      }

      .nav-links a:hover,
      .nav-links a:focus-visible,
      .nav-links a[aria-current="page"] {
        background: var(--brand-glow);
        color: var(--brand-dark);
        outline: none;
      }

      .nav-links a[aria-current="page"] {
        box-shadow: inset 0 0 0 1px rgba(20, 184, 166, 0.28);
      }

      .language-switcher {
        display: inline-flex;
        align-items: center;
        gap: 0.2rem;
        padding: 0.2rem;
        border: 1px solid var(--stroke);
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.72);
      }

      .language-switcher a {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 2rem;
        min-height: 1.9rem;
        padding: 0 0.45rem;
        border-radius: 999px;
        font-size: 0.74rem;
        font-weight: 700;
        color: var(--muted);
        transition:
          background var(--transition),
          color var(--transition);
      }

      .language-switcher a:hover,
      .language-switcher a:focus-visible,
      .language-switcher a[aria-current="true"] {
        background: var(--brand-glow);
        color: var(--brand-dark);
        outline: none;
      }

      main {
        min-height: 60vh;
      }

      footer {
        margin-top: 3rem;
        border-top: 1px solid var(--stroke);
        padding: 1.5rem 0;
      }

      footer p {
        margin: 0;
        text-align: center;
        color: var(--muted);
        font-size: 0.84rem;
      }

      @media (max-width: 640px) {
        nav {
          gap: 0.5rem;
        }

        .logo {
          height: 1.6rem;
        }

        .nav-tools {
          gap: 0.45rem;
        }

        .nav-links {
          gap: 0;
          flex-wrap: wrap;
          justify-content: flex-end;
        }

        .nav-links a {
          padding: 0.35rem 0.45rem;
          font-size: 0.84rem;
        }

        .language-switcher {
          width: 100%;
          justify-content: flex-end;
        }
      }
    </style>
  </body>
</html>
